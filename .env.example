# Optional: GitHub personal access token for private contributions.
# Without this token the dashboard shows public data only.
# Create at: https://github.com/settings/tokens
# Required scopes: repo, read:user
GITHUB_TOKEN=ghp_xxx

# Optional: Google Site Verification code for search console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: GitHub username to fetch data for (defaults to mhaitana)
GITHUB_USERNAME=
